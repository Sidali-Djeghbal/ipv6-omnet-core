version 3
run TCP_Baseline-0-20260412-18:21:51-17918
attr configname TCP_Baseline
attr datetime 20260412-18:21:51
attr datetimef 20260412-182151
attr experiment TCP_Baseline
attr inifile omnetpp.ini
attr iterationvars ""
attr iterationvarsd ""
attr iterationvarsf ""
attr measurement ""
attr network src.BasicNetwork
attr processid 17918
attr repetition 0
attr replication #0
attr resultdir results
attr runnumber 0
attr seedset 0
config image-path ../inet/images
config extends Part_II_Base
config description "TCP Baseline: Bottleneck 10 Mbps (light congestion)"
config **.tcp.cwnd:vector true
config **.tcp.rtt:vector true
config **.tcp.sndNxt:vector true
config **.tcp.sndUna:vector true
config description "Part II Foundation: TCP/UDP apps for transport protocol testing"
config extends RIPng
config *.client1.numApps 1
config *.client1.app[0].typename TcpSessionApp
config *.client1.app[0].connectAddress "\"server1\""
config *.client1.app[0].connectPort 1000
config *.client1.app[0].tOpen 1s
config *.client1.app[0].tSend 2s
config *.client1.app[0].tClose 90s
config *.client1.app[0].sendBytes 10MB
config *.server1.numApps 1
config *.server1.app[0].typename TcpSinkApp
config *.server1.app[0].localPort 1000
config *.client2.numApps 1
config *.client2.app[0].typename UdpBasicApp
config *.client2.app[0].destAddresses "\"server2\""
config *.client2.app[0].destPort 2000
config *.client2.app[0].messageLength 1000B
config *.client2.app[0].sendInterval 0.01s
config *.server2.numApps 1
config *.server2.app[0].typename UdpSink
config *.server2.app[0].localPort 2000
config **.tcp.cwnd:vector true
config **.tcp.rtt:vector true
config description "Dynamic routing with RIPng (Distance-Vector, IPv6)"
config *.configurator.addStaticRoutes false
config *.configurator.addDefaultRoutes false
config **.r[*].hasRip true
config **.r[*].rip.mode "\"RIPng\""
config **.r[*].rip.updateInterval 30s
config **.r[*].rip.routeExpiryTime 180s
config **.r[*].rip.routePurgeTime 120s
config network src.BasicNetwork
config sim-time-limit 100s
config seed-set 0
config output-scalar-file results/TCP_Baseline-0.sca
config output-vector-file results/TCP_Baseline-0.vec
config **.eth[*].queue.queueLength:vector true
config **.udpApp[*].rcvdPk:vector true
config *.configurator.addStaticRoutes true
config *.configurator.addDefaultRoutes true
config *.configurator.addSubnetRoutes true
config **.hasIpv6 true
config **.hasIpv4 false
config **.tcp.typename Tcp
config **.tcp.tcpAlgorithmClass "\"TcpReno\""


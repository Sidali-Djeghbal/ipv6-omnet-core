<!-- 
    ospf_config.xml  –  OSPFv3 configuration for BasicNetwork (IPv6)

    OSPFv3 in INET requires one <Router> entry per router.
    All routers are placed in Area 0 (backbone).
    Interfaces are identified by name (eth0, eth1, ...) in the
    order they appear in the NED connections block:

    r1:  eth0 = client1   eth1 = r2   eth2 = r4
    r2:  eth0 = r1        eth1 = r3   eth2 = r5 (bottleneck)
    r3:  eth0 = r2        eth1 = server1  eth2 = r6
    r4:  eth0 = client2   eth1 = r5   eth2 = r1
    r5:  eth0 = r4        eth1 = r6   eth2 = r2 (bottleneck)
    r6:  eth0 = r5        eth1 = server2  eth2 = r3
 -->
<OSPFv3Configuration>
<Router id="r1" ipv6="true">
<Area id="0.0.0.0">
<Interface name="eth0" type="PointToPoint"/>
<Interface name="eth1" type="PointToPoint"/>
<Interface name="eth2" type="PointToPoint"/>
</Area>
</Router>
<Router id="r2" ipv6="true">
<Area id="0.0.0.0">
<Interface name="eth0" type="PointToPoint"/>
<Interface name="eth1" type="PointToPoint"/>
<Interface name="eth2" type="PointToPoint" metric="100"/>
</Area>
</Router>
<Router id="r3" ipv6="true">
<Area id="0.0.0.0">
<Interface name="eth0" type="PointToPoint"/>
<Interface name="eth1" type="PointToPoint"/>
<Interface name="eth2" type="PointToPoint"/>
</Area>
</Router>
<Router id="r4" ipv6="true">
<Area id="0.0.0.0">
<Interface name="eth0" type="PointToPoint"/>
<Interface name="eth1" type="PointToPoint"/>
<Interface name="eth2" type="PointToPoint"/>
</Area>
</Router>
<Router id="r5" ipv6="true">
<Area id="0.0.0.0">
<Interface name="eth0" type="PointToPoint"/>
<Interface name="eth1" type="PointToPoint"/>
<Interface name="eth2" type="PointToPoint" metric="100"/>
</Area>
</Router>
<Router id="r6" ipv6="true">
<Area id="0.0.0.0">
<Interface name="eth0" type="PointToPoint"/>
<Interface name="eth1" type="PointToPoint"/>
<Interface name="eth2" type="PointToPoint"/>
</Area>
</Router>
</OSPFv3Configuration>